<?xml version="1.0" encoding="utf-8"?>
<installer-gui-script minSpecVersion="1">
    <title>AnimeRestore Denoise</title>
    <welcome file="welcome.html" mime-type="text/html"/>
    <conclusion file="conclusion.html" mime-type="text/html"/>
    <options customize="never" require-scripts="false" hostArchitectures="arm64"/>
    <domains enable_localSystem="true"/>
    <volume-check>
        <allowed-os-versions>
            <os-version min="11.0"/>
        </allowed-os-versions>
    </volume-check>
    <choices-outline>
        <line choice="default"/>
    </choices-outline>
    <choice id="default" title="AnimeRestore Denoise">
        <pkg-ref id="com.animerestore.denoise"/>
    </choice>
    <pkg-ref id="com.animerestore.denoise" version="__VERSION__" onConclusion="none">AnimeRestore-component.pkg</pkg-ref>
</installer-gui-script>
